# .env
# PanenCerdas ML Service — Environment Variables

# ── DATABASE ───────────────────────────────────────────
# Development: SQLite (default, tidak perlu diubah)
DATABASE_URL=sqlite:///./panencerdas_ml.db

# Production: ganti ke PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/panencerdas

# ── SERVER ─────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── CORS ───────────────────────────────────────────────
# Dev: "*" sudah cukup. PROD: frontend kini menembak FastAPI LANGSUNG untuk
# semua GET, jadi origin frontend WAJIB diizinkan di sini (bukan cuma Express).
# Comma-separated, tanpa trailing slash.
# Contoh: https://panen-cerdas.vercel.app,https://panen-cerdas-express.onrender.com
ALLOWED_ORIGINS=*

# ── RETRAIN SCHEDULER ──────────────────────────────────
RETRAIN_FEEDBACK_THRESHOLD=10   # retrain setiap N feedback baru
RETRAIN_CRON_HOUR=2             # jam retrain terjadwal (02.00)
RETRAIN_CRON_DAY=sunday         # hari retrain terjadwal

# ── NASA APPEEARS (untuk fetch NDVI real) ──────────────
# Daftar gratis di: https://appeears.earthdatacloud.nasa.gov/
# Tanpa ini, NDVI akan menggunakan estimasi musiman sebagai fallback
APPEEARS_USER=email_kamu@gmail.com
APPEEARS_PASS=password_kamu
